# ── GitHub routing ─────────────────────────────────────────
route_github() {
    local url="$1"
    local slug

    slug=$(echo "$url" | sed -E 's|https?://github\.com/||; s|/$||')

    if [[ "$slug" =~ /issues/([0-9]+) ]]; then
        slug="${slug%/issues/*}"
        gh issue view "${BASH_REMATCH[1]}" --repo "$slug" 2>/dev/null && return 0
        gh issue view "${BASH_REMATCH[1]}" --repo "$slug" --comments 2>/dev/null && return 0
        return 2
    fi

    if [[ "$slug" =~ /pull/([0-9]+) ]]; then
        slug="${slug%/pull/*}"
        gh pr view "${BASH_REMATCH[1]}" --repo "$slug" 2>/dev/null && return 0
        gh pr view "${BASH_REMATCH[1]}" --repo "$slug" --comments 2>/dev/null && return 0
        return 2
    fi

    gh api "repos/$slug" --jq '.description' 2>/dev/null && return 0
    return 2
}

# ── Parse result count ────────────────────────────────────
parse_result_count() {
    echo "$1" | grep -oP '结果数:\s*\K[0-9]+' 2>/dev/null || echo "0"
}

# ── BGE-Reranker integration ───────────────────────────────
rerank_results() {
    local query="$1"
    RERANK_URL="$RERANK_URL" RERANK_MODEL="$RERANK_MODEL" web-rerank "$query" 2>/dev/null
}

# ── Format reranked JSON as text ─────────────────────────
format_reranked_output() {
    local query="$1"
    local display_count="$2"
    web-format-json "$query" "$display_count" 2>/dev/null
}

# ── SearXNG search with reranking + quality gate + 3 retries ─
do_search_reranked() {
    local query="$1"; shift
    local extra_args=("$@")
    local display_count=5

    # Extract --count if specified
    for ((i=0; i<${#extra_args[@]}; i++)); do
        if [ "${extra_args[$i]}" = "--count" ]; then
            display_count="${extra_args[$((i+1))]}"
            break
        fi
    done

    # Fetch 2x results for reranking
    local fetch_count=$((display_count * 2))
    [ "$fetch_count" -lt 10 ] && fetch_count=10

    # Temp files for JSON passing
    local tmp_raw=$(mktemp /tmp/web_raw.XXXXXX)
    local tmp_reranked=$(mktemp /tmp/web_reranked.XXXXXX)
    _WEB_TMPFILES+=("$tmp_raw" "$tmp_reranked")

    # Build raw args: strip --count, add --count N --raw
    local raw_args=()
    local skip_next=false
    for ((i=0; i<${#extra_args[@]}; i++)); do
        if [ "$skip_next" = "true" ]; then skip_next=false; continue; fi
        if [ "${extra_args[$i]}" = "--count" ]; then skip_next=true; continue; fi
        raw_args+=("${extra_args[$i]}")
    done
    raw_args+=("--count" "$fetch_count" "--raw")

    # Search + rerank + quality check, write result to tmp_reranked
    # Returns 0 if quality pass, 1 if fail
    do_one_search() {
        local -a sargs=("$@")
        if timeout "$SEARX_TIMEOUT" "$SEARX_BIN" "$query" "${sargs[@]}" > "$tmp_raw" 2>/dev/null; then
            local count
            export _WEB_TMP="$tmp_raw"
            count=$(python3 -c "
import json, os
data = json.load(open(os.environ['_WEB_TMP']))
print(len(data.get('results',[])))
" 2>/dev/null || echo "0")
            if [ "$count" -ge "$MIN_RESULTS" ]; then
                cat "$tmp_raw" | rerank_results "$query" > "$tmp_reranked" 2>/dev/null
                # Quality gate
                local pass
                export _WEB_TMPR="$tmp_reranked"
                pass=$(python3 -c "
import json, os
data = json.load(open(os.environ['_WEB_TMPR']))
results = data.get('results', [])
rerank = data.get('_rerank', {})
if rerank.get('status') != 'ok':
    print('pass'); exit()
top5 = results[:5]
if not top5:
    print('fail'); exit()
scores = [r.get('rerank_score', 0) for r in top5]
avg = sum(scores) / len(scores)
mx = max(scores)
domains = set()
for r in top5:
    url = r.get('url', '')
    if '/' in url: domains.add(url.split('/')[2])
if avg >= 0.5:
    print('pass')
elif avg >= 0.3 and mx >= 0.5 and len(domains) >= 2:
    print('pass')
else:
    print('fail')
" 2>/dev/null || echo "pass")
                if [ "$pass" = "pass" ]; then
                    return 0
                fi
            fi
        fi
        return 1
    }

    # Attempt 0: original search
    if do_one_search "${raw_args[@]}"; then
        cat "$tmp_reranked" | format_reranked_output "$query" "$display_count"
        return 0
    fi

    # Attempt 1: simplify to bare search (no category, no engine)
    echo "🔄 重试: 简化搜索..." >&2
    local retry_raw=("--count" "$fetch_count" "--raw")
    # Carry forward --lang and --time if present
    for ((i=0; i<${#extra_args[@]}; i++)); do
        case "${extra_args[$i]}" in
            --lang|--time) retry_raw+=("${extra_args[$i]}" "${extra_args[$((i+1))]}"); i=$((i+1)) ;;
        esac
    done
    if do_one_search "${retry_raw[@]}"; then
        cat "$tmp_reranked" | format_reranked_output "$query" "$display_count"
        return 0
    fi

    # All retries failed — fallback
    if [ -s "$tmp_reranked" ]; then
        echo "⚠️  搜索质量偏低，以下为最佳可用结果" >&2
        cat "$tmp_reranked" | format_reranked_output "$query" "$display_count"
        return 1
    fi

    echo "" >&2
    echo "⚠️  SearXNG unavailable (host: $SEARX_HOST)" >&2
    echo "👉 FALLBACK: Use built-in WebSearch tool instead" >&2
    return 1
}

# ── SearXNG search (no rerank) with retry logic ────────────
do_search() {
    local query="$1"; shift
    local extra_args=("$@")

    # Try search, return 0 if enough results
    try_text_search() {
        local -a sargs=("$@")
        local output
        if output=$(timeout "$SEARX_TIMEOUT" "$SEARX_BIN" "$query" "${sargs[@]}" 2>/dev/null); then
            local count
            count=$(parse_result_count "$output")
            if [ "$count" -ge "$MIN_RESULTS" ]; then
                echo "$output"
                return 0
            fi
        fi
        return 1
    }

    # Attempt 0: original
    if try_text_search "${extra_args[@]}"; then
        return 0
    fi

    # Attempt 1: bare search (strip category/engine)
    echo "🔄 重试: 简化搜索..." >&2
    local retry_args=()
    local skip=false
    for a in "${extra_args[@]}"; do
        if [ "$skip" = "true" ]; then skip=false; continue; fi
        case "$a" in
            --lang|--time) retry_args+=("$a"); skip=false ;;
            --it|--science|--packages|--repos|--qa|--videos|--images|--wiki|--books|--social|--weather|--map|--news) ;;
            --engine) skip=true ;;
            *) retry_args+=("$a") ;;
        esac
    done
    if try_text_search "${retry_args[@]}"; then
        return 0
    fi

    echo "⚠️  SearXNG 搜索结果不足" >&2
    echo "👉 FALLBACK: Use built-in WebSearch tool instead" >&2
    return 1
}

# ── URL fetch ──────────────────────────────────────────────
do_fetch() {
    local url="$1"
    if [[ "$url" =~ ^https?://github\.com ]]; then
        if check_gh; then
            route_github "$url" && return 0
        fi
        echo "⚠️  gh CLI unavailable — falling back to web-extract" >&2
    fi
    # Use web-extract with full extraction chain (text-only for fast fetch)
    if command -v web-extract &>/dev/null; then
        web-extract "$url" --no-vision 2>/dev/null && return 0
        echo "⚠️  web-extract failed — falling back to SearXNG fetch" >&2
    fi
    if check_searx; then
        local fetch_output
        if fetch_output=$("$SEARX_BIN" "$url" 2>/dev/null) && [ -n "$fetch_output" ]; then
            echo "$fetch_output"
            return 0
        fi
    fi
    echo "⚠️  All fetch methods failed" >&2
    echo "👉 FALLBACK: Use built-in WebFetch tool instead" >&2
    return 1
}

# ── Full extraction ────────────────────────────────────────
do_extract() {
    local url="$1"
    shift || true
    if command -v web-extract &>/dev/null; then
        web-extract "$url" "$@" && return 0
    fi
    # Fallback to do_fetch
    do_fetch "$url"
}

# ── Main dispatch ──────────────────────────────────────────
[[ $# -eq 0 ]] && usage

CMD="${1:-}"; shift || true

QUERY=""
EXTRA=()
NO_RERANK=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --engine|--time|--count|--lang) EXTRA+=("$1" "$2"); shift 2 ;;
        --engine=*|--time=*|--count=*|--lang=*) EXTRA+=("$1"); shift ;;
        --no-rerank) NO_RERANK=true; shift ;;
        # Pass through web-extract flags (don't eat as QUERY)
        --no-vision|--vision|--no-text|--raw|--raw-html|--summarize|--no-summarize) EXTRA+=("$1"); shift ;;
        --mode|--crawler) EXTRA+=("$1" "$2"); shift 2 ;;
        --mode=*|--crawler=*) EXTRA+=("$1"); shift ;;
        --format|--max-chars|--max-images) EXTRA+=("$1" "$2"); shift 2 ;;
        --format=*|--max-chars=*|--max-images=*) EXTRA+=("$1"); shift ;;
        # Category flags pass through to searx
        --it|--science|--packages|--repos|--qa|--videos|--images|--wiki|--books|--social|--weather|--map)
            EXTRA+=("$1"); shift ;;
        *)
            if [ -z "$QUERY" ]; then
                QUERY="$1"; shift
            else
                EXTRA+=("$1"); shift
            fi
            ;;
    esac
done

# Helper: choose search function based on --no-rerank flag
run_search() {
    if [ "$NO_RERANK" = "true" ]; then
        do_search "$@"
    else
        do_search_reranked "$@"
    fi
}

case "$CMD" in
    search)
        [ -z "$QUERY" ] && usage
        run_search "$QUERY" "${EXTRA[@]}"
        ;;
    fetch)
        [ -z "$QUERY" ] && usage
        do_fetch "$QUERY"
        ;;
    extract|full)
        [ -z "$QUERY" ] && usage
        do_extract "$QUERY" "${EXTRA[@]}"
        ;;
    vision|extract-images)
        [ -z "$QUERY" ] && usage
        if command -v web-extract &>/dev/null; then
            web-extract "$QUERY" --vision "${EXTRA[@]}" && exit $?
        fi
        echo "⚠️  web-extract not available" >&2
        exit 1
        ;;
    news)
        [ -z "$QUERY" ] && usage
        run_search "$QUERY" --news "${EXTRA[@]}"
        ;;
    deep)
        [ -z "$QUERY" ] && usage
        # deep: search + read top 5 full text with web-extract
        echo "🔍 深度搜索: $QUERY"
        echo ""

        deep_tmp=$(mktemp /tmp/web_deep.XXXXXX)
        _WEB_TMPFILES+=("$deep_tmp")

        deep_raw_args=()
        ds=false
        for a in "${EXTRA[@]}"; do
            if [ "$ds" = "true" ]; then ds=false; continue; fi
            if [ "$a" = "--count" ]; then ds=true; continue; fi
            deep_raw_args+=("$a")
        done
        deep_raw_args+=("--count" "5" "--raw")

        # Detect language: use --it for English, bare multi-engine for Chinese/CJK
        deep_cat=("--it")
        if echo "$QUERY" | python3 -c "
import sys
q = sys.stdin.read()
has_cjk = any('\u4e00' <= c <= '\u9fff' or '\u3040' <= c <= '\u30ff' or '\uac00' <= c <= '\ud7af' for c in q)
sys.exit(0 if has_cjk else 1)
" 2>/dev/null; then
            deep_cat=()  # CJK query: use all engines, don't restrict to --it
        fi

        if timeout "$SEARX_TIMEOUT" "$SEARX_BIN" "$QUERY" "${deep_cat[@]}" "${deep_raw_args[@]}" > "$deep_tmp" 2>/dev/null; then
            urls=$(python3 -c "
import json,sys
data = json.load(open('$deep_tmp'))
for r in data.get('results',[])[:5]:
    print(r.get('url',''))
" 2>/dev/null)

            # Format search results
            cat "$deep_tmp" | rerank_results "$QUERY" 2>/dev/null | format_reranked_output "$QUERY" "5" 2>/dev/null || python3 -c "
import json
data = json.load(open('$deep_tmp'))
for i,r in enumerate(data.get('results',[])[:5],1):
    print(f'[{i}] {r.get(\"title\",\"\")}')
    print(f'    URL: {r.get(\"url\",\"\")}')
    print(f'    {r.get(\"content\",\"\")[:200]}')
    print()
" 2>/dev/null

            # Phase 2: parallel extraction (text-only for speed)
            if [ -n "$urls" ] && command -v web-extract &>/dev/null; then
                echo "═══ 全文提取 ═══"

                # Collect URLs with index, spawn extractors in background
                deep_jobs_tmp=$(mktemp /tmp/web_deep_jobs.XXXXXX)
                _WEB_TMPFILES+=("$deep_jobs_tmp")
                idx=1
                while IFS= read -r url; do
                    [ -z "$url" ] && continue
                    ext_tmp=$(mktemp /tmp/web_ext_${idx}.XXXXXX)
                    _WEB_TMPFILES+=("$ext_tmp")
                    echo "${idx}|${url}|${ext_tmp}" >> "$deep_jobs_tmp"
                    idx=$((idx + 1))
                done <<< "$urls"

                # Launch all in background, wait for completion
                while IFS='|' read -r job_idx job_url job_tmp; do
                    (
                        { echo ""; echo "─── [$job_idx] ───"; web-extract "$job_url" --max-chars 8000 --no-vision --summarize 2>/dev/null || echo "⚠️ 提取失败"; } > "$job_tmp"
                    ) &
                done < "$deep_jobs_tmp"
                wait

                # Concatenate in original order
                while IFS='|' read -r job_idx job_url job_tmp; do
                    cat "$job_tmp" 2>/dev/null
                done < "$deep_jobs_tmp"
            fi
        else
            echo "⚠️ 搜索失败，降级到 do_search"
            do_search "$QUERY" "${EXTRA[@]}"
        fi
        ;;
    synthesize)
        [ -z "$QUERY" ] && usage
        if command -v web-synthesize &>/dev/null; then
            web-synthesize --from-deep "$QUERY" --max-chars "${SYNTHESIZE_CHARS:-4000}" "${EXTRA[@]}" && exit $?
        fi
        echo "⚠️  web-synthesize not available" >&2
        echo "👉 FALLBACK: use web deep instead" >&2
        exit 1
        ;;
    it)
        [ -z "$QUERY" ] && usage
        run_search "$QUERY" --it "${EXTRA[@]}"
        ;;
    science)
