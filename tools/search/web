#!/bin/bash
# ============================================================
# web — Unified search/fetch dispatcher for Claude Code
# ============================================================
# Routes queries to the right backend with automatic fallback.
# Backed by SearXNG with 249 engines across 31 categories.
#
# Usage:
#   web search <query>            Keyword search (multi-engine)
#   web fetch <url>               Fetch URL content (auto-detect)
#   web extract <url>             Full content extraction (text + auto image desc)
#   web full <url>                Alias for extract
#   web vision <url>              Force image descriptions
#   web extract-images <url>      Alias for vision
#   web news <query>              News search
#   web deep <query>              Search + read top 5 results
#   web synthesize <query>        Multi-source research synthesis (MapReduce)
#   web it <query>                IT/dev search (GitHub/SO/npm/...)
#   web science <query>           Academic search (arXiv/PubMed/...)
#   web packages <query>          Package search (npm/PyPI/crates/...)
#   web repos <query>             Code repos (GitHub/GitLab/HF/...)
#   web qa <query>                Q&A (StackOverflow/AskUbuntu/...)
#   web videos <query>            Video search
#   web probe                     Full health check (engines + categories)
#
# Exit codes:
#   0 — success (≥ MIN_RESULTS)
#   1 — SearXNG unavailable or low-quality → use WebSearch/WebFetch
#   2 — gh CLI unavailable → use searx or WebFetch
#   3 — invalid usage
# ============================================================

set -euo pipefail

# Global timeout guard: kill the whole script after WEB_MAX_TIMEOUT seconds
# Prevents runaway processes from blocking Claude Code for 20+ minutes
# deep/extract commands get longer timeout (5 URLs × 60s each)
_WEB_CMD="${1:-}"
case "$_WEB_CMD" in
    deep|extract|full) _WEB_DEFAULT_TIMEOUT=300 ;;
    *) _WEB_DEFAULT_TIMEOUT=60 ;;
esac
WEB_MAX_TIMEOUT="${WEB_MAX_TIMEOUT:-$_WEB_DEFAULT_TIMEOUT}"
if [ -z "${_WEB_WATCHDOG:-}" ] && [ "${WEB_MAX_TIMEOUT}" -gt 0 ]; then
    export _WEB_WATCHDOG=1
    (
        sleep "$WEB_MAX_TIMEOUT"
        kill -KILL $$ 2>/dev/null || true
    ) &
fi

# Global temp file registry for cleanup
_WEB_TMPFILES=()
_web_cleanup() {
    for f in "${_WEB_TMPFILES[@]}"; do
        [ -n "$f" ] && rm -f "$f" 2>/dev/null || true
    done
}
trap _web_cleanup EXIT

# Source shared config (single source of truth for all services)
if [ -f "${WEB_CONFIG:-$HOME/.config/web-search/env}" ]; then
    . "${WEB_CONFIG:-$HOME/.config/web-search/env}"
fi

SEARX_BIN="${SEARX_BIN:-searx}"
SEARX_HOST="${SEARXNG_URL:-http://192.168.20.21:8005}"
SEARX_TIMEOUT="${SEARX_TIMEOUT:-30}"
MIN_RESULTS="${WEB_MIN_RESULTS:-3}"
RERANK_URL="${RERANK_URL:-http://172.16.90.45:8082}"
RERANK_MODEL="${RERANK_MODEL:-scs_bge-reranker}"
RERANK_ENABLED="${RERANK_ENABLED:-true}"

# ── Help ───────────────────────────────────────────────────
usage() {
    cat <<'EOF'
web — Unified search/fetch dispatcher (249 engines, 31 categories)

Usage:
  web search   <query>         Keyword search (multi-engine, most stable)
  web fetch    <url>           Fetch page content
  web news     <query>         News search
  web deep     <query>         Search + read top 5 full text
  web it       <query>         IT/dev (GitHub, SO, npm, PyPI, crates, HF, MDN...)
  web science  <query>         Academic (arXiv, PubMed, Google Scholar...)
  web packages <query>         Packages (npm, PyPI, crates.io, Docker Hub...)
  web repos    <query>         Code repos (GitHub, GitLab, HuggingFace...)
  web qa       <query>         Q&A (StackOverflow, AskUbuntu...)
  web videos   <query>         Videos (YouTube, Bilibili...)
  web images   <query>         Images
  web gh       <args>          GitHub CLI shortcut
  web probe                    Full health check

Flags:
  --engine E     Specify single engine (usually unnecessary)
  --time T       Time filter (day|week|month|year)
  --count N      Results count (default 5)
  --lang L       Language (zh-CN|en|all)
  --no-rerank    Skip BGE-Reranker (default: enabled)

Exit codes:
  0 — success (≥3 results)
  1 — SearXNG unavailable or <3 results → use WebSearch/WebFetch
  2 — gh CLI unavailable
EOF
    exit 3
}

# ── Health checks ──────────────────────────────────────────
check_searx() {
    curl -s -o /dev/null -w '%{http_code}' --max-time 3 \
        "$SEARX_HOST/config" 2>/dev/null | grep -q '^2' && return 0
    return 1
}

check_gh() {
    command -v gh &>/dev/null && gh auth status &>/dev/null && return 0
    return 1
}

# ── Comprehensive probe ───────────────────────────────────
probe_full() {
